# Private overlay for Tofino testbed configs — template.
#
# Copy this file to `secrets.local.toml` (which is gitignored) and fill in the
# real values for your testbed.  Then run `python3 apply_secrets.py` to
# regenerate config_*.local.toml, and pass those files to
# BaseNetwork(config_file=...).

USER              = "your-ssh-username"
JUMPHOST          = "jumphost.example.com"

OCS_SWITCH_IP     = "10.0.0.10"
TOR_SWITCH_IP     = "10.0.0.11"
TOR_SWITCH_NAME   = "tor-switch-1"

# Server 1 (attached to logical ToR 0)
SERVER1_MAC       = "aa:bb:cc:dd:ee:01"
SERVER1_HOST_IP   = "10.1.0.1"
SERVER1_MGMT_IP   = "10.0.1.1"

# Server 2 (attached to logical ToR 1)
SERVER2_MAC       = "aa:bb:cc:dd:ee:02"
SERVER2_HOST_IP   = "10.1.0.2"
SERVER2_MGMT_IP   = "10.0.1.2"
